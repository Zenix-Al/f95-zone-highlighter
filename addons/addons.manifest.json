{
  "addons": [
    {
      "id": "image-repair-addon",
      "name": "F95UE Image Repair Add-on",
      "description": "Automatically retries broken attachment images on F95Zone threads.",
      "version": "0.2.1",
      "author": "X Death",
      "entry": "addons/image-repair-addon/src/main.js",
      "outfile": "addons/image-repair-addon/dist/image-repair-addon.user.js",
      "matches": [
        "*://f95zone.to/threads/*"
      ],
      "grants": [
        "none"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "capabilities": [
        "toast",
        "feature",
        "storage",
        "observer",
        "ui",
        "ui.style"
      ]
    },
    {
      "id": "masked-direct-addon",
      "name": "F95UE Masked + Direct Download Add-on",
      "description": "Combines masked-link skipper and direct-download flows into one trusted add-on.",
      "version": "0.3.16",
      "author": "X Death",
      "entry": "addons/masked-direct-addon/src/main.js",
      "outfile": "addons/masked-direct-addon/dist/masked-direct-addon.user.js",
      "matches": [
        "*://f95zone.to/threads/*",
        "*://f95zone.to/masked/*",
        "*://buzzheavier.com/*",
        "*://*.buzzheavier.com/*",
        "*://gofile.io/*",
        "*://pixeldrain.com/*",
        "*://datanodes.to/*",
        "*://www.mediafire.com/file/*",
        "*://mediafire.com/file/*"
      ],
      "grants": [
        "GM_openInTab",
        "GM.getValue",
        "GM.setValue",
        "GM_addValueChangeListener",
        "GM_removeValueChangeListener"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "capabilities": [
        "toast",
        "feature",
        "storage",
        "ui",
        "ui.style"
      ]
    },
    {
      "id": "library-addon",
      "name": "F95UE Library Add-on",
      "description": "Quick-add threads to a personal library and manage entries with a dedicated add-on UI.",
      "version": "0.3.44",
      "author": "X Death",
      "entry": "addons/library-addon/src/main.js",
      "outfile": "addons/library-addon/dist/library-addon.user.js",
      "matches": [
        "*://f95zone.to/*"
      ],
      "grants": [
        "none"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "capabilities": [
        "toast",
        "feature",
        "storage",
        "idb",
        "ui",
        "ui.mount",
        "ui.style",
        "ui.dialog"
      ]
    },
    {
      "id": "latest-filters-addon",
      "name": "F95UE Latest Filters Add-on",
      "description": "Adds one Saved Filters button on Latest Updates with a searchable preset list and active filter tracking.",
      "version": "0.3.16",
      "author": "X Death",
      "entry": "addons/latest-filters-addon/src/main.js",
      "outfile": "addons/latest-filters-addon/dist/latest-filters-addon.user.js",
      "matches": [
        "*://f95zone.to/sam/latest_alpha/*"
      ],
      "grants": [
        "GM.getValue",
        "GM.setValue"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "capabilities": [
        "toast",
        "feature",
        "storage",
        "ui",
        "ui.style",
        "ui.mount",
        "ui.dialog"
      ]
    },
    {
      "id": "halloween-theme-addon",
      "name": "F95UE Halloween Theme Add-on",
      "description": "Forces Halloween logo/background theme with simple apply and teardown lifecycle.",
      "version": "2.0.11",
      "author": "X Death",
      "entry": "addons/halloween-theme-addon/src/main.js",
      "outfile": "addons/halloween-theme-addon/dist/halloween-theme-addon.user.js",
      "matches": [
        "*://f95zone.to/*"
      ],
      "grants": [
        "none"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "capabilities": [
        "feature"
      ]
    }
  ]
}