{
  "addons": [
    {
      "id": "image-repair-addon",
      "name": "F95UE Image Repair Add-on",
      "description": "Automatically retries broken attachment images on F95Zone threads.",
      "version": "0.2.3",
      "author": "X Death",
      "entry": "addons/image-repair-addon/src/main.js",
      "outfile": "addons/image-repair-addon/dist/image-repair-addon.user.js",
      "matches": [
        "*://f95zone.to/threads/*"
      ],
      "grants": [
        "none"
      ],
      "runAt": "document-idle",
      "requiresCore": true,
      "runtimeMode": "core-required",
      "pageScopes": ["thread"],
      "downloadUrl": "https://greasyfork.org/en/scripts/572502-f95ue-image-repair-add-on",
      "capabilities": [
        "toast",
        "feature",
        "storage",
        "observer",
        "ui",
        "ui.style"
      ]
    },
